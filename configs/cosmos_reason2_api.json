        "VANTAGE_SOT": {},
        "VANTAGE_2DGrounding": {
            "class": "VANTAGE_2DGroundingDataset",
            "dataset": "VANTAGE_2DGrounding"
        },
        "VANTAGE_2DPointing": {
            "class": "VANTAGE_2DPointing",
            "dataset": "VANTAGE_2DPointing"
        },
        "Astro2D": {
            "class": "Astro2DDetectionDataset",
            "dataset": "Astro2D"
        }
    }
